{
  "__inputs": [
    {
      "name": "DS_SUPABASE",
      "label": "Supabase PostgreSQL",
      "description": "Supabase PostgreSQL data source",
      "type": "datasource",
      "pluginId": "grafana-postgresql-datasource",
      "pluginName": "PostgreSQL"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "Pressure Monitoring",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "gauge",
      "title": "Supply PSI (Current)",
      "datasource": { "uid": "${DS_SUPABASE}" },
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "psi",
          "min": 0,
          "max": 80,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 20 },
              { "color": "green", "value": 30 },
              { "color": "orange", "value": 60 },
              { "color": "red", "value": 70 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT supply_psi AS \"Supply PSI\" FROM pressure_log WHERE supply_psi IS NOT NULL ORDER BY ts DESC LIMIT 1;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Avg PSI (1h)",
      "datasource": { "uid": "${DS_SUPABASE}" },
      "gridPos": { "h": 3, "w": 2, "x": 4, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "psi",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 20 },
              { "color": "green", "value": 30 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND(AVG(supply_psi), 1) AS \"Avg\" FROM pressure_log WHERE supply_psi IS NOT NULL AND ts > NOW() - INTERVAL '1 hour';",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Min PSI (1h)",
      "datasource": { "uid": "${DS_SUPABASE}" },
      "gridPos": { "h": 3, "w": 2, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "psi",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 15 },
              { "color": "green", "value": 25 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND(MIN(supply_psi), 1) AS \"Min\" FROM pressure_log WHERE supply_psi IS NOT NULL AND ts > NOW() - INTERVAL '1 hour';",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Max PSI (1h)",
      "datasource": { "uid": "${DS_SUPABASE}" },
      "gridPos": { "h": 3, "w": 2, "x": 4, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "psi",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 60 },
              { "color": "red", "value": 70 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND(MAX(supply_psi), 1) AS \"Max\" FROM pressure_log WHERE supply_psi IS NOT NULL AND ts > NOW() - INTERVAL '1 hour';",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Readings (1h)",
      "datasource": { "uid": "${DS_SUPABASE}" },
      "gridPos": { "h": 3, "w": 2, "x": 6, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Count\" FROM pressure_log WHERE supply_psi IS NOT NULL AND ts > NOW() - INTERVAL '1 hour';",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Supply Pressure Over Time",
      "datasource": { "uid": "${DS_SUPABASE}" },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "psi",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 60 }
            ]
          },
          "custom.thresholdsStyle": { "mode": "dashed" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "High Threshold" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Low Threshold" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "rawSql": "SELECT\n  date_trunc('minute', ts) AS time,\n  ROUND(AVG(supply_psi), 1) AS \"Supply PSI\"\nFROM pressure_log\nWHERE ts > $__timeFrom() AND ts < $__timeTo()\n  AND supply_psi IS NOT NULL\nGROUP BY 1\nORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT\n  date_trunc('minute', ts) AS time,\n  60 AS \"High Threshold\",\n  20 AS \"Low Threshold\"\nFROM pressure_log\nWHERE ts > $__timeFrom() AND ts < $__timeTo()\n  AND supply_psi IS NOT NULL\nGROUP BY 1\nORDER BY 1;",
          "format": "time_series",
          "refId": "B"
        }
      ]
    },
    {
      "type": "row",
      "title": "Zone Activity",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Zones Run Today",
      "datasource": { "uid": "${DS_SUPABASE}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Runs\" FROM zone_history WHERE started_at >= CURRENT_DATE;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total Runtime Today",
      "datasource": { "uid": "${DS_SUPABASE}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(ROUND(SUM(duration_min), 1), 0) AS \"Minutes\" FROM zone_history WHERE started_at >= CURRENT_DATE AND duration_min IS NOT NULL;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "barchart",
      "title": "Runtime by Zone (Last 7 Days)",
      "datasource": { "uid": "${DS_SUPABASE}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "groupWidth": 0.7,
        "barWidth": 0.8
      },
      "targets": [
        {
          "rawSql": "SELECT\n  'Zone ' || zone_num AS \"Zone\",\n  ROUND(COALESCE(SUM(duration_min), 0), 0) AS \"Runtime (min)\"\nFROM zone_history\nWHERE started_at > NOW() - INTERVAL '7 days'\n  AND duration_min IS NOT NULL\nGROUP BY zone_num\nORDER BY zone_num;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Recent Zone Runs",
      "datasource": { "uid": "${DS_SUPABASE}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Started" },
            "properties": [{ "id": "unit", "value": "dateTimeAsLocal" }]
          },
          {
            "matcher": { "id": "byName", "options": "Duration" },
            "properties": [{ "id": "unit", "value": "m" }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Started", "desc": true }]
      },
      "targets": [
        {
          "rawSql": "SELECT\n  zone_num AS \"Zone\",\n  started_at AS \"Started\",\n  ROUND(duration_min, 1) AS \"Duration\",\n  source AS \"Source\"\nFROM zone_history\nORDER BY started_at DESC\nLIMIT 20;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Zone Activity Timeline",
      "datasource": { "uid": "${DS_SUPABASE}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT\n  date_trunc('hour', started_at) AS time,\n  zone_num AS metric,\n  COUNT(*) AS value\nFROM zone_history\nWHERE started_at > $__timeFrom() AND started_at < $__timeTo()\nGROUP BY 1, 2\nORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Alerts & System Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Unacknowledged Alerts",
      "datasource": { "uid": "${DS_SUPABASE}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Alerts\" FROM device_alerts WHERE acknowledged = false;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Recent Alerts",
      "datasource": { "uid": "${DS_SUPABASE}" },
      "gridPos": { "h": 8, "w": 12, "x": 4, "y": 23 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "unit", "value": "dateTimeAsLocal" }]
          },
          {
            "matcher": { "id": "byName", "options": "Severity" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "critical": { "color": "red", "text": "CRITICAL" }, "warning": { "color": "orange", "text": "WARNING" }, "info": { "color": "blue", "text": "INFO" } } }
                ]
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawSql": "SELECT\n  created_at AS \"Time\",\n  severity AS \"Severity\",\n  title AS \"Title\",\n  description AS \"Description\",\n  device AS \"Device\",\n  CASE WHEN acknowledged THEN 'Yes' ELSE 'No' END AS \"Ack\"\nFROM device_alerts\nORDER BY created_at DESC\nLIMIT 20;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Pressure Distribution (5-min avg)",
      "datasource": { "uid": "${DS_SUPABASE}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "unit": "psi",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT\n  date_trunc('minute', ts) - (EXTRACT(MINUTE FROM ts)::int % 5) * INTERVAL '1 minute' AS time,\n  ROUND(MIN(supply_psi), 1) AS \"Min PSI\",\n  ROUND(AVG(supply_psi), 1) AS \"Avg PSI\",\n  ROUND(MAX(supply_psi), 1) AS \"Max PSI\"\nFROM pressure_log\nWHERE ts > $__timeFrom() AND ts < $__timeTo()\n  AND supply_psi IS NOT NULL\nGROUP BY 1\nORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["irrigation", "sandy-soil", "farm"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m"],
    "time_options": ["1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "timezone": "Australia/Melbourne",
  "title": "Sandy Soil - Farm Monitoring",
  "uid": "sandy-soil-farm",
  "version": 1
}
